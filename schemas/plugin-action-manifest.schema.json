{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kata-agent.local/schemas/plugin-action-manifest.schema.json",
  "title": "PluginActionManifest",
  "type": "object",
  "required": [
    "id",
    "title",
    "inputSchema",
    "outputSchema",
    "sideEffects"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "inputSchema": {
      "type": "string"
    },
    "outputSchema": {
      "type": "string"
    },
    "sideEffects": {
      "type": "object",
      "required": ["network", "writeArtifacts", "external"],
      "properties": {
        "network": { "type": "boolean" },
        "writeArtifacts": { "type": "boolean" },
        "external": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
