{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kata-agent.local/schemas/plugin-manifest.schema.json",
  "title": "PluginManifest",
  "type": "object",
  "required": ["name", "title", "version", "type", "actions", "permissions"],
  "properties": {
    "name": { "type": "string" },
    "title": { "type": "string" },
    "version": { "type": "string" },
    "type": {
      "type": "string",
      "enum": [
        "requirement-source",
        "artifact-export",
        "automation",
        "notification",
        "issue-tracker",
        "requirement-writeback",
        "rule-source",
        "static-scan"
      ]
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "inputSchema",
          "outputSchema",
          "sideEffects"
        ],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "inputSchema": { "type": "string" },
          "outputSchema": { "type": "string" },
          "sideEffects": {
            "type": "object",
            "required": ["network", "writeArtifacts", "external"],
            "properties": {
              "network": { "type": "boolean" },
              "writeArtifacts": { "type": "boolean" },
              "external": { "type": "boolean" }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "permissions": {
      "type": "object",
      "required": ["network", "secrets", "writeScopes"],
      "properties": {
        "network": {
          "type": "string",
          "enum": ["none", "restricted", "open"]
        },
        "secrets": {
          "type": "array",
          "items": { "type": "string" }
        },
        "writeScopes": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
