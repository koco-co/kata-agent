{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kata-agent.local/schemas/hotfix-case-gen-input.schema.json",
  "title": "HotfixCaseGenInput",
  "type": "object",
  "required": [
    "schemaVersion",
    "project",
    "feature",
    "issueDraftRef",
    "sourceRepoRef"
  ],
  "properties": {
    "schemaVersion": { "const": "0.1" },
    "project": {
      "type": "string",
      "minLength": 1,
      "not": { "pattern": "[/\\\\]|^\\.$|^\\.\\.$|^[A-Za-z]:" }
    },
    "feature": {
      "type": "string",
      "minLength": 1,
      "not": { "pattern": "[/\\\\]|^\\.$|^\\.\\.$|^[A-Za-z]:" }
    },
    "issueDraftRef": { "type": "string", "minLength": 1 },
    "sourceRepoRef": { "type": "string", "minLength": 1 },
    "inspectionReportRef": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
