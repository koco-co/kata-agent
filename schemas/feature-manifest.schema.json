{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kata-agent.local/schemas/feature-manifest.schema.json",
  "title": "FeatureManifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "project",
    "feature",
    "createdAt",
    "status"
  ],
  "properties": {
    "schemaVersion": {
      "const": "0.1"
    },
    "project": {
      "type": "string"
    },
    "feature": {
      "type": "string"
    },
    "createdAt": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "in-progress",
        "blocked",
        "completed",
        "archived"
      ]
    }
  },
  "additionalProperties": true
}
