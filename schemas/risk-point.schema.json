{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kata-agent.local/schemas/risk-point.schema.json",
  "title": "RiskPoint",
  "type": "object",
  "required": [
    "id",
    "severity",
    "category",
    "title",
    "description",
    "evidence",
    "recommendation"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "severity": { "type": "string", "enum": ["P0", "P1", "P2", "P3"] },
    "category": {
      "type": "string",
      "enum": [
        "debug-code",
        "unsafe-code",
        "missing-test-signal",
        "state-risk",
        "dependency-risk"
      ]
    },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "filePath": {
      "type": "string",
      "minLength": 1,
      "allOf": [
        { "not": { "pattern": "^/" } },
        { "not": { "pattern": "^[A-Za-z]:" } },
        { "not": { "pattern": "\\\\" } },
        { "not": { "pattern": "//" } },
        { "not": { "pattern": "/$" } },
        { "not": { "pattern": "(^|/)\\.($|/)" } },
        { "not": { "pattern": "(^|/)\\.\\.($|/)" } }
      ]
    },
    "line": { "type": "integer", "minimum": 1 },
    "evidence": { "type": "string" },
    "recommendation": { "type": "string" }
  },
  "additionalProperties": false
}
