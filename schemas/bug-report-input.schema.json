{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kata-agent.local/schemas/bug-report-input.schema.json",
  "title": "BugReportInput",
  "type": "object",
  "required": ["schemaVersion", "project", "feature", "runId", "caseResults"],
  "properties": {
    "schemaVersion": { "const": "0.1" },
    "project": {
      "type": "string",
      "minLength": 1,
      "not": { "pattern": "[/\\\\]|^\\.$|^\\.\\.$|^[A-Za-z]:" }
    },
    "feature": {
      "type": "string",
      "minLength": 1,
      "not": { "pattern": "[/\\\\]|^\\.$|^\\.\\.$|^[A-Za-z]:" }
    },
    "runId": { "type": "string" },
    "caseResults": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["testCaseId", "status", "flowTitle", "failedSteps"],
        "properties": {
          "testCaseId": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "error", "skipped", "blocked"]
          },
          "flowTitle": { "type": "string" },
          "failedSteps": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["stepId", "action", "selector", "expected", "error"],
              "properties": {
                "stepId": { "type": "string" },
                "action": { "type": "string" },
                "selector": { "type": "string" },
                "expected": { "type": "string" },
                "error": { "type": "string" },
                "screenshotPath": {
                  "type": "string",
                  "pattern": "^automation/evidence/(?:[A-Za-z0-9][A-Za-z0-9_-]*/)*[A-Za-z0-9][A-Za-z0-9._-]*\\.(txt|json|png|zip|log)$"
                },
                "consoleLogs": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
