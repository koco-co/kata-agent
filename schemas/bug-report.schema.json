{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kata-agent.local/schemas/bug-report.schema.json",
  "title": "BugReport",
  "type": "object",
  "required": ["schemaVersion", "project", "feature", "runId", "bugs"],
  "properties": {
    "schemaVersion": { "const": "0.1" },
    "project": {
      "type": "string",
      "minLength": 1,
      "not": { "pattern": "[/\\\\]|^\\.$|^\\.\\.$|^[A-Za-z]:" }
    },
    "feature": {
      "type": "string",
      "minLength": 1,
      "not": { "pattern": "[/\\\\]|^\\.$|^\\.\\.$|^[A-Za-z]:" }
    },
    "runId": { "type": "string" },
    "bugs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "severity",
          "testCaseId",
          "flowId",
          "stepId",
          "expected",
          "actual"
        ],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "severity": { "type": "string", "enum": ["P0", "P1", "P2"] },
          "testCaseId": { "type": "string" },
          "flowId": { "type": "string" },
          "stepId": { "type": "string" },
          "expected": { "type": "string" },
          "actual": { "type": "string" },
          "screenshotRef": { "type": "string" },
          "consoleLogRef": { "type": "string" },
          "recommendation": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
