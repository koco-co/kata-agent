{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kata-agent.local/schemas/confirmation-result.schema.json",
  "title": "ConfirmationResult",
  "type": "object",
  "required": [
    "schemaVersion",
    "answers"
  ],
  "properties": {
    "schemaVersion": {
      "const": "0.1"
    },
    "answers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "questionId",
          "status"
        ],
        "properties": {
          "questionId": {
            "type": "string"
          },
          "status": {
            "enum": [
              "confirmed",
              "rejected",
              "assumed",
              "unanswered"
            ]
          },
          "answer": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}
