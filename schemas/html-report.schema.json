{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kata-agent.local/schemas/html-report.schema.json",
  "title": "HtmlReport",
  "type": "object",
  "required": [
    "schemaVersion",
    "format",
    "outputPath",
    "runId",
    "status"
  ],
  "properties": {
    "schemaVersion": {
      "const": "0.1"
    },
    "format": {
      "type": "string",
      "enum": ["html"]
    },
    "outputPath": {
      "type": "string",
      "pattern": "^(?!/)(?!.*\\.\\.)[A-Za-z0-9._/-]+\\.html$"
    },
    "runId": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["passed", "failed", "blocked"]
    }
  },
  "additionalProperties": false
}
