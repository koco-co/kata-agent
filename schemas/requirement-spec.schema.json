{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kata-agent.local/schemas/requirement-spec.schema.json",
  "title": "RequirementSpec",
  "type": "object",
  "required": [
    "schemaVersion",
    "project",
    "feature",
    "title",
    "status",
    "rules",
    "pageContracts",
    "openItems",
    "assumptions"
  ],
  "properties": {
    "schemaVersion": {
      "const": "0.1"
    },
    "project": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!\\.\\.?$)(?![A-Za-z]:)[^/\\\\]+$"
    },
    "feature": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!\\.\\.?$)(?![A-Za-z]:)[^/\\\\]+$"
    },
    "title": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "confirmed",
        "assumed",
        "blocked"
      ]
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "text",
          "severity",
          "sourceType",
          "sourceRefs"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "P0",
              "P1",
              "P2",
              "P3"
            ]
          },
          "sourceType": {
            "type": "string",
            "enum": [
              "source",
              "confirmation",
              "assumption",
              "unknown"
            ]
          },
          "sourceRefs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "confirmationQuestionId": {
            "type": "string"
          },
          "assumptionRef": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "pageContracts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "surface"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "surface": {
            "type": "string",
            "enum": [
              "web",
              "mobile",
              "desktop",
              "api"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "openItems": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "severity",
          "status",
          "question"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "P0",
              "P1",
              "P2",
              "P3"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "unconfirmed",
              "confirmed",
              "assumed",
              "deferred"
            ]
          },
          "question": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "content",
          "risk"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "risk": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
